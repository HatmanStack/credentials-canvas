{
  "name": "credentials-canvas",
  "version": "0.1.0",
  "private": true,
  "description": "Interactive 3D Portfolio Experience",
  "homepage": "https://www.cg-portfolio.site",
  "scripts": {
    "start": "cd frontend && npx vite",
    "dev": "cd frontend && npx vite",
    "build": "cd frontend && npx tsc && npx vite build",
    "preview": "cd frontend && npx vite preview",
    "test": "cd frontend && npx vitest",
    "lint": "cd frontend && npx eslint src && npx tsc --noEmit",
    "check": "npm run lint && cd frontend && npx vitest --run",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7"
  }
}
